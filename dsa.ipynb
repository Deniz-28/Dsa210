import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.stats import pearsonr, ttest_ind, f_oneway

# DATA LOAD
df = pd.read_csv("Social Media and Mental Health.csv")

# Sütunları kısalt
df = df.rename(columns={
    'Gender ?': 'Gender',
    'What is your age?': 'Age',
    'On average, how many hours per day do you spend on social media?': 'Usage',
    'How would you rate your current daily stress level?': 'Stress'
})

# Sayıya çevir (çok önemli)
df['Usage'] = pd.to_numeric(df['Usage'], errors='coerce')
df['Stress'] = pd.to_numeric(df['Stress'], errors='coerce')

# Eksik verileri temizle
df = df.dropna(subset=['Usage', 'Stress'])

# -------------------
# 📊 EDA
# -------------------

# Histogram
sns.histplot(df['Usage'])
plt.title("Social Media Usage")
plt.show()

sns.histplot(df['Stress'])
plt.title("Stress Level")
plt.show()

# Ortalama değerler
print("Usage by Gender:")
print(df.groupby('Gender')['Usage'].mean())

print("\nStress by Age:")
print(df.groupby('Age')['Stress'].mean())

# Scatter plot
sns.scatterplot(x='Usage', y='Stress', data=df)
plt.title("Usage vs Stress")
plt.show()

# -------------------
# 🧠 HYPOTHESIS TESTS
# -------------------

# 1️⃣ Correlation
corr, p = pearsonr(df['Usage'], df['Stress'])
print("\nCorrelation:", corr)
print("P-value:", p)

# 2️⃣ Gender t-test
male = df[df['Gender'] == 'Male']['Stress']
female = df[df['Gender'] == 'Female']['Stress']

t_stat, p_val = ttest_ind(male, female)
print("\nT-test p-value (Gender):", p_val)

# 3️⃣ Age ANOVA
groups = [group['Stress'].values for name, group in df.groupby('Age')]
anova = f_oneway(*groups)

print("\nANOVA p-value (Age):", anova.pvalue)